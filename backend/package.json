{
  "name": "chore-ganizer-backend",
  "version": "2.1.10",
  "description": "Backend API for Chore-ganizer",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathIgnorePatterns='integration'",
    "test:integration": "jest --config=jest.integration.config.js --runInBand --detectOpenHandles",
    "test:all": "npm run test:coverage && npm run test:integration",
    "docs:generate": "ts-node --transpile-only scripts/generate-swagger.ts",
    "docs:validate": "ts-node --transpile-only scripts/generate-swagger.ts --validate"
  },
  "keywords": [
    "chore",
    "family",
    "management"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.15.2",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.1",
    "express-session": "^1.17.3",
    "helmet": "^8.1.0",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.6",
    "prom-client": "^15.1.0",
    "tar": "^7.5.11",
    "uuid": "^13.0.0",
    "winston": "^3.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.19.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.39",
    "@types/node-cache": "^4.2.5",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/uuid": "^11.0.0",
    "jest": "^30.0.0",
    "nodemon": "^3.0.2",
    "npm": "^11.13.0",
    "prisma": "^5.7.1",
    "supertest": "^7.1.3",
    "swagger-jsdoc": "^6.2.8",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "tar": "^7.5.11",
    "glob": {
      "minimatch": "^10.2.3"
    },
    "ignore-walk": {
      "minimatch": "^10.2.3"
    },
    "@tootallnate/once": ">=3.0.1",
    "path-to-regexp": "0.1.13"
  }
}
