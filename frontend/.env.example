# Chore-Ganizer Frontend Configuration — LOCAL DEV ONLY, WITHOUT DOCKER
# Copy this file to frontend/.env and customize. This only matters when
# running `cd frontend && npm run dev` (Vite dev server on :5173; the port
# and API proxy target for that dev server are hardcoded in vite.config.ts,
# not read from here).
# The Docker Compose deployment does not use this file — it passes its own
# VITE_API_URL/VITE_DEBUG/VITE_APP_VERSION via docker-compose.yml instead
# (see the root .env.example), injected at container start into
# window.APP_CONFIG (frontend/src/lib/apiClient.ts reads apiUrl from it).

# Only needed if your frontend and backend are served from different
# origins (e.g. testing against a remote backend from a local Vite dev
# server). Leave unset for the normal same-origin setup — api calls default
# to relative paths, which the Vite dev proxy (see vite.config.ts) already
# routes to http://localhost:3010.
# VITE_API_URL=http://localhost:3010
