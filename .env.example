# ===========================================
# Chore-Ganizer Configuration
# ===========================================
# Copy this file to .env and customize for your environment.
# Docker Compose reads this file and passes variables to containers at runtime.
# Changes to .env take effect on container restart (no rebuild needed).
# NEVER commit .env to git if it contains secrets.
#
# Every variable below is actually read by the app. If you're looking for a
# setting and it's not here, it doesn't exist yet -- check
# .planning/codebase/INTEGRATIONS.md for planned-but-unimplemented features.

# ===========================================
# APPLICATION VERSION
# ===========================================
# Auto-synced from backend/package.json by ./docker-compose.sh on every run --
# don't hand-edit this to a value that differs from backend/frontend
# package.json. Only matters here as a fallback if you run raw `docker
# compose` instead of the helper script.
APP_VERSION=3.2.0

# ===========================================
# DATA DIRECTORY (BIND MOUNT)
# ===========================================
# Host path where the SQLite database is stored. Bind-mounted into the
# container at the same location. Must exist on the host before starting.
DATA_DIR=/opt/app-data/chore-ganizer

# Docker Compose supports SQLite database files under DATA_DIR only. To use a
# different filename, set an absolute file: path under DATA_DIR and keep
# BACKUP_DATABASE_FILE in sync below.
# DATABASE_URL=file:/opt/app-data/chore-ganizer/chore-ganizer.db

# ===========================================
# CONTAINER USER/GROUP IDs (BIND MOUNT OWNERSHIP)
# ===========================================
# Files created by the container are owned by these UID/GID. Set to match
# your host user to avoid permission issues (find with: id -u && id -g).
# Default: 1001 (container's built-in appuser)
PUID=1001
PGID=1001

# ===========================================
# BACKEND CONFIGURATION
# ===========================================

# Environment mode (development/production)
NODE_ENV=production

# Server port (host port mapping in docker-compose)
PORT=3010

# Session Secret (CRITICAL: Generate a strong random secret)
# Generate with: openssl rand -base64 32
# IMPORTANT: Change this in production!
SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARACTERS

# Session max age in milliseconds (604800000 = 7 days)
SESSION_MAX_AGE=604800000

# ===========================================
# FIRST PARENT BOOTSTRAP
# ===========================================
# Required only for the first startup of an empty production database.
# Set real, unique values below before starting. An empty production database
# refuses to start until all three required values are set. Creates one PARENT
# and no demo chores/templates. Remove these values after the first successful
# login.
# BOOTSTRAP_PARENT_NAME=Your Name
# BOOTSTRAP_PARENT_EMAIL=you@example.com
# BOOTSTRAP_PARENT_PASSWORD=use-a-strong-temporary-password
# BOOTSTRAP_PARENT_COLOR=#4F46E5

# Enable secure cookies for HTTPS (true/false) -- set true in production w/ SSL
SECURE_COOKIES=false

# SameSite cookie attribute: "strict", "lax", or "none"
# Controls the session cookie only; the CSRF cookie remains Strict. Default is
# "strict" (safest). Use "lax" if cross-site top-level navigations need the
# cookie, or "none" (requires SECURE_COOKIES=true).
SAMESITE_POLICY=strict

# CORS - the URL where the frontend is accessible to users
# Example: https://chores.yourdomain.com
CORS_ORIGIN=http://localhost:3002

# Rate limiting: max requests per 15min window on /api, and on POST
# /api/auth/login specifically. For e2e/UAT runs (many logins in a short
# window), temporarily raise these much higher, e.g. RATE_LIMIT_MAX=1000,
# AUTH_RATE_LIMIT_MAX=500 -- see docs/project_notes/bugs.md's 2026-07-12
# "Auth rate-limit counter persists" entry. Don't leave raised values in
# place for live use.
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10

# ===========================================
# FRONTEND CONFIGURATION
# ===========================================
# Runtime values passed to the frontend container; nginx generates
# config.js at startup with these values.

# API URL - leave empty for same-origin via nginx proxy (default).
# Only set if the frontend needs to reach a different backend host.
VITE_API_URL=

# Frontend port (host port mapping, optional override)
# FRONTEND_PORT=3002

# ===========================================
# NTFY NOTIFICATION SETTINGS
# ===========================================
# Leave NTFY_BASE_URL empty to disable notifications entirely (the app
# no-ops gracefully). Per-user topics are set in each user's Profile page.

# ntfy server URL, e.g. https://ntfy.sh or your self-hosted instance
NTFY_BASE_URL=

# ===========================================
# PASSWORD RECOVERY (SMTP)
# ===========================================
# SMTP configuration for password reset emails. Leave all empty to disable
# password recovery (the "Forgot password?" link will be hidden on login).
#
# Gmail setup:
#   1. Enable 2FA on your Google account
#   2. Generate an App Password at https://myaccount.google.com/apppasswords
#   3. Use the 16-char App Password as SMTP_PASS (not your regular password)

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-16-char-app-password
# SMTP_FROM=you@gmail.com

# Frontend URL used in password reset email links
# FRONTEND_URL=https://chore.thitar.ovh

# ===========================================
# BACKUPS
# ===========================================
# Host path for SQLite backup files. Must exist on the host before starting.
BACKUP_DIR=/opt/app-data/chore-ganizer-backups

# Backups always read the SQLite database from DATA_DIR. Set this when
# DATABASE_URL uses a filename other than chore-ganizer.db; do not include a
# path, and keep it in sync with DATABASE_URL.
# BACKUP_DATABASE_FILE=chore-ganizer.db

# Backup schedule (crond format, default: daily at 3am UTC)
# BACKUP_SCHEDULE=0 3 * * *

# Days to retain (default: 14)
# BACKUP_RETENTION_DAYS=14
